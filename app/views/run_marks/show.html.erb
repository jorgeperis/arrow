<% if notice.present? %>
  <div popover class="flash" style="--flash-position: 5rem;" data-controller="element-removal" data-action="animationend->element-removal#remove" role="alert"><%= notice %></div>
<% end %>

<h1 class="font-bold text-3xl mbe-4"><%= @run_mark.full_name %></h1>

<%= render @run_mark %>

<div class="flex flex-wrap items-center gap mbs-6" style="--row-gap: .5rem">
  <%= link_to "Edit this run mark", edit_run_mark_path(@run_mark), class: "btn" %>
  <%= link_to "Back to run marks", run_marks_path, class: "btn" %>
  <%= button_to "Destroy this run mark", @run_mark, method: :delete, class: "btn" %>
</div>
