<%= form_with(model: [@shoes, montly_distance], html: { contents: true }) do |form| %>
  <% if montly_distance.errors.any? %>
    <div class="alert alert--negative flex flex-col gap-half mbe-4" role="alert">
      <h2 class="font-medium leading-none"><%= pluralize(montly_distance.errors.count, "error") %> prohibited this montly_distance from being saved:</h2>

      <ul class="text-sm mis-3" style="list-style: disc">
        <% montly_distance.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex flex-col items-start gap-half mbe-4">
    <%= form.label :month, class: "text-sm font-medium leading-none" %>
    <%= form.date_field :month, class: "input input--datepicker", data: { controller: "datepicker" } %>
  </div>

  <div class="flex flex-col items-start gap-half mbe-4">
    <%= form.label :distance, class: "text-sm font-medium leading-none" %>
    <%= form.number_field :distance, class: "input", step: "0.001", inputmode: :decimal %>
  </div>

  <div class="inline-flex items-center mbs-2 mie-1">
    <%= form.submit class: "btn btn--primary" %>
  </div>
<% end %>
