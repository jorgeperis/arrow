<% if notice.present? %>
  <div popover class="flash" style="--flash-position: 5rem;" data-controller="element-removal" data-action="animationend->element-removal#remove" role="alert"><%= notice %></div>
<% end %>

<%= render @montly_distance %>

<div class="flex flex-wrap items-center gap mbs-6" style="--row-gap: .5rem">
  <%= link_to "Edit this montly distance", edit_montly_distance_path(@montly_distance), class: "btn" %>
  <%= link_to "Back to #{@montly_distance.shoes.full_name}", @montly_distance.shoes, class: "btn" %>
  <%= button_to "Destroy this montly distance", @montly_distance, method: :delete, class: "btn" %>
</div>
