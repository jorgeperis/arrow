<%= form_with(model: goal) do |form| %>
  <% if goal.errors.any? %>
    <div class="alert alert--negative flex flex-col gap-half mbe-4" role="alert">
      <h2 class="font-medium leading-none"><%= pluralize(goal.errors.count, "error") %> prohibited this goal from being saved:</h2>

      <ul class="text-sm mis-3" style="list-style: disc">
        <% goal.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="goal-form-fields">
    <div class="flex flex-col gap-half">
      <%= form.label :distance, class: "text-sm font-medium leading-none" %>
      <%= form.select :distance,
            options_for_select(COMMON_RACE_DISTANCES.map { |km, data| [ data[:name], km ] }, goal.distance&.to_s),
            { include_blank: "Select distance..." }, class: "input" %>
    </div>

    <div class="flex flex-col gap-half">
      <%= form.label :target_time_formatted, "Target time", class: "text-sm font-medium leading-none" %>
      <%= form.text_field :target_time_formatted, class: "input", inputmode: "numeric",
            placeholder: "h:mm:ss", autocomplete: "off", data: { controller: "duration-input" } %>
    </div>

    <%= form.submit goal.persisted? ? "Update goal" : "Add goal", class: "btn btn--primary" %>
  </div>
<% end %>
