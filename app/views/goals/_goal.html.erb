<% distance_data = COMMON_RACE_DISTANCES[goal.distance.to_s] %>
<% color = distance_data ? distance_data[:colors][:dark] : "var(--color-accent)" %>
<div class="goal-card" style="--goal-color: <%= color %>">
  <div class="goal-card-head">
    <span class="goal-card-distance"><%= goal.name %></span>
    <span class="goal-card-target">Target <%= decorated_time_for(goal.target_time) %></span>
  </div>

  <div class="goal-progress">
    <div class="goal-progress-bar" style="width: <%= (goal.progress * 100).round %>%"></div>
  </div>

  <div class="goal-card-foot">
    <% if goal.best_run %>
      <span class="goal-card-current">
        Best <%= decorated_time_for(goal.best_run.time) %>
        <% if goal.achieved? %>
          <span class="goal-badge goal-badge--done">Achieved 🎉</span>
        <% else %>
          <span class="goal-gap"><%= decorated_time_for(goal.best_run.time - goal.target_time) %> to go</span>
        <% end %>
      </span>
    <% else %>
      <span class="goal-card-current text-subtle">No result at this distance yet</span>
    <% end %>

    <% if local_assigns[:actions] %>
      <span class="goal-card-actions">
        <%= link_to "Edit", edit_goal_path(goal), class: "btn btn--small" %>
        <%= button_to "Delete", goal_path(goal), method: :delete, class: "btn btn--small btn--secondary",
              form: { data: { turbo_confirm: "Delete this goal?" } } %>
      </span>
    <% end %>
  </div>
</div>
