<% if notice.present? %>
  <div popover class="flash" style="--flash-position: 5rem;" data-controller="element-removal" data-action="animationend->element-removal#remove" role="alert"><%= notice %></div>
<% end %>

<% content_for :title, "Goals" %>

<div class="flex items-center justify-between mbe-4">
  <h1 class="font-bold text-4xl">Goals</h1>
  <%= link_to "Back to stats", stats_path, class: "btn" %>
</div>

<div class="card mbe-6">
  <h3 class="font-semibold leading-none mbe-3">New goal</h3>
  <%= render "form", goal: @goal %>
</div>

<% if @goals.any? %>
  <div class="goals-list">
    <%= render partial: "goal", collection: @goals, locals: { actions: true } %>
  </div>
<% else %>
  <p class="text-subtle">No goals yet. Add a target time above to start tracking one.</p>
<% end %>
