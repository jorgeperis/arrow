<%= form_with(model: shoes, html: { contents: true }) do |form| %>
  <% if shoes.errors.any? %>
    <div class="alert alert--negative flex flex-col gap-half mbe-4" role="alert">
      <h2 class="font-medium leading-none"><%= pluralize(shoes.errors.count, "error") %> prohibited this shoes from being saved:</h2>

      <ul class="text-sm mis-3" style="list-style: disc">
        <% shoes.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :brand, class: "text-sm font-medium leading-none" %>
    <%= form.text_field :brand, class: "input" %>
  </div>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :model, class: "text-sm font-medium leading-none" %>
    <%= form.text_field :model, class: "input" %>
  </div>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :size, class: "text-sm font-medium leading-none" %>
    <%= form.text_field :size, class: "input" %>
  </div>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :purchased_at, class: "text-sm font-medium leading-none" %>
    <%= form.date_field :purchased_at, class: "input" %>
  </div>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :price, class: "text-sm font-medium leading-none" %>
    <%= form.text_field :price, class: "input" %>
  </div>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :retired_at, class: "text-sm font-medium leading-none" %>
    <%= form.date_field :retired_at, class: "input" %>
  </div>

  <div class="inline-flex items-center mbs-2 mie-1">
    <%= form.submit class: "btn btn--primary" %>
  </div>
<% end %>
