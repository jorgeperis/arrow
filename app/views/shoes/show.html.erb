<% if notice.present? %>
  <div popover class="flash" style="--flash-position: 5rem;" data-controller="element-removal" data-action="animationend->element-removal#remove" role="alert"><%= notice %></div>
<% end %>

<% content_for :title, @shoes.full_name %>

<div class="mbe-6">
  <div class="flex items-center gap-4 mbe-2">
    <h1 class="font-bold text-3xl"><%= @shoes.full_name %></h1>
  </div>
  <div class="flex items-center justify-between">
    <div class="badge <%= @shoes.active? ? "badge--positive" : "badge--negative" %>">
      <%= @shoes.active? ? "ACTIVE" : "RETIRED" %>
    </div>
    <div class="flex" style="gap: 0.5rem">
      <%= link_to "Edit", edit_shoes_path(@shoes), class: "btn" %>
      <%= button_to "Destroy", @shoes, method: :delete, class: "btn", data: { turbo_confirm: "Are you sure?" } %>
    </div>
  </div>
</div>

<div class="flex flex-wrap mbe-4" style="gap: 0.5rem">
  <div class="card" style="flex: 1; min-width: 120px">
    <p class="text-xs color-text-muted mbe-1">Size (USA)</p>
    <p class="font-medium"><%= @shoes.size %></p>
  </div>

  <div class="card" style="flex: 1; min-width: 120px">
    <p class="text-xs color-text-muted mbe-1">Purchased</p>
    <p class="font-medium"><%= @shoes.purchased_at.strftime("%b %d, %Y") %></p>
  </div>
</div>

<div class="card mbs-4">
  <div class="flex items-center justify-between mbe-4">
    <p class="text-sm color-text-muted">Usage</p>
    <p class="text-sm"><%= @shoes.distance.round(0) %> / <%= MAX_KM_FOR_SHOES %> km</p>
  </div>
  <progress value="<%= @shoes.distance %>" max="<%= MAX_KM_FOR_SHOES %>" class="progress" style="width: 100%"></progress>
</div>

<div class="flex items-center justify-between mbe-4 mbs-8">
  <h2 class="font-bold text-2xl">Monthly Distances</h2>
  <%= link_to "Add Distance", new_shoes_montly_distance_path(@shoes), class: "btn btn--primary" %>
</div>

<% if @shoes.montly_distances.any? %>
  <table class="table">
    <thead>
      <tr>
        <th>Month</th>
        <th>Distance</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @shoes.montly_distances.ordered.each do |montly_distance| %>
        <tr>
          <td><%= montly_distance.month.strftime("%B %Y") %></td>
          <td><%= distance_in_km(montly_distance.distance) %></td>
          <td class="text-right">
            <%= link_to "Edit", edit_montly_distance_path(montly_distance), class: "text-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="card text-center">
    <p class="color-text-muted mbe-4">No distances recorded yet</p>
    <%= link_to "Add First Distance", new_shoes_montly_distance_path(@shoes), class: "btn btn--primary" %>
  </div>
<% end %>

<div class="flex mbs-6">
  <%= link_to "← Back to Shoes", shoes_index_path, class: "btn" %>
</div>
