<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Runtally" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :all, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="header-layout">
    <header id="header">
      <div class="container flex items-center">
        <h1 class="text-3xl font-semibold">// Runtally</h1>
        <nav>
          <ul class="flex space-x-4 mis-6">
            <li><%= link_to 'Stats', root_path, class: "text-lg m-2" %></li>
            <li><%= link_to 'Races', races_path, class: "text-lg m-2" %></li>
            <li><%= link_to 'Run marks', run_marks_path, class: "text-lg m-2" %></li>
            <li><%= link_to 'Shoes', shoes_index_path, class: "text-lg m-2" %></li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="main">
      <div class="container">
        <%= yield %>
      </div>
    </main>
  </body>
</html>
