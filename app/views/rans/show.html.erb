<% if notice.present? %>
  <div popover class="flash" style="--flash-position: 5rem;" data-controller="element-removal" data-action="animationend->element-removal#remove" role="alert"><%= notice %></div>
<% end %>

<h1 class="font-bold text-3xl mbe-4"><%= @ran.full_name %></h1>

<%= render @ran %>

<div class="flex flex-wrap items-center gap mbs-6" style="--row-gap: .5rem">
  <%= link_to "Edit this ran", edit_ran_path(@ran), class: "btn" %>
  <%= link_to "Back to rans", rans_path, class: "btn" %>
  <%= button_to "Destroy this ran", @ran, method: :delete, class: "btn" %>
</div>
